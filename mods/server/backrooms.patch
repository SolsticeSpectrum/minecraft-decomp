+    protected static final class Backrooms implements DensityFunction.SimpleFunction {
+        public static final KeyDispatchDataCodec<Backrooms> CODEC = KeyDispatchDataCodec.of(MapCodec.unit(Backrooms::new));
+        private static final int FLOOR_Y = 64;
+        private static final int ROOM_HEIGHT = 4;
+        private static final int CELL = 16;
+        private static final int WALL = 1;
+
+        private long hash(long x, long z) {
+            long h = x * 3129871L ^ z * 116129781L;
+            return h * h * 42317861L + h * 11L;
+        }
+
+        private long hash3(long x, long y, long z) {
+            long h = x * 3129871L ^ y * 116129781L ^ z * 982451653L;
+            return h * h * 42317861L + h * 11L;
+        }
+
+        private int roomType(int cx, int cz) {
+            return (int) ((hash(cx, cz) & 0x7FFFFFFFL) % 8);
+        }
+
+        private boolean hasNorthDoor(int cx, int cz) {
+            return ((hash(cx, cz) >> 4) & 3) != 0;
+        }
+
+        private boolean hasSouthDoor(int cx, int cz) {
+            return ((hash(cx, cz) >> 6) & 3) != 0;
+        }
+
+        private boolean hasWestDoor(int cx, int cz) {
+            return ((hash(cx, cz) >> 8) & 3) != 0;
+        }
+
+        private boolean hasEastDoor(int cx, int cz) {
+            return ((hash(cx, cz) >> 10) & 3) != 0;
+        }
+
+        private boolean hasPillar(int cx, int cz, int px, int pz) {
+            int type = roomType(cx, cz);
+            if (type < 2) return false;
+            if (type < 5) {
+                return (px == 4 || px == 11) && (pz == 4 || pz == 11);
+            }
+            if (type == 5) {
+                return px == 7 || px == 8;
+            }
+            if (type == 6) {
+                return pz == 7 || pz == 8;
+            }
+            return ((hash3(cx, px, cz * 17 + pz) >> 12) & 7) == 0 && px > 2 && px < 13 && pz > 2 && pz < 13;
+        }
+
+        private boolean hasPartialWall(int cx, int cz, int lx, int lz) {
+            int type = roomType(cx, cz);
+            if (type == 3) {
+                if (lx >= 6 && lx <= 9 && lz == 8) return true;
+            }
+            if (type == 4) {
+                if (lz >= 6 && lz <= 9 && lx == 8) return true;
+            }
+            if (type == 7) {
+                long h = hash3(cx, lx / 4, cz * 31 + lz / 4);
+                if (((h >> 16) & 15) == 0) {
+                    int wx = lx % 4, wz = lz % 4;
+                    if (wx == 0 || wz == 0) return true;
+                }
+            }
+            return false;
+        }
+
+        @Override
+        public double compute(DensityFunction.FunctionContext ctx) {
