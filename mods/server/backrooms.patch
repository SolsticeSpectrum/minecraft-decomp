+
+            if (y < FLOOR_Y || y > FLOOR_Y + ROOM_HEIGHT) return 1.0;
+
+            int cx = Math.floorDiv(x, CELL);
+            int cz = Math.floorDiv(z, CELL);
+            int lx = Math.floorMod(x, CELL);
+            int lz = Math.floorMod(z, CELL);
+
+            boolean onFloor = y == FLOOR_Y;
+            boolean onCeiling = y == FLOOR_Y + ROOM_HEIGHT;
+            if (onFloor || onCeiling) return 1.0;
+
+            boolean northWall = lz < WALL;
+            boolean southWall = lz >= CELL - WALL;
+            boolean westWall = lx < WALL;
+            boolean eastWall = lx >= CELL - WALL;
+
+            if (northWall && westWall) return 1.0;
+            if (northWall && eastWall) return 1.0;
+            if (southWall && westWall) return 1.0;
+            if (southWall && eastWall) return 1.0;
+
