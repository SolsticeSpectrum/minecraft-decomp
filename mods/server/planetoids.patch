+    protected record Planetoids(int min, int max, int gap) implements DensityFunction.SimpleFunction {
+        private static final MapCodec<DensityFunctions.Planetoids> DATA_CODEC = RecordCodecBuilder.mapCodec(
+            i -> i.group(
+                    Codec.INT.fieldOf("min").forGetter(DensityFunctions.Planetoids::min),
+                    Codec.INT.fieldOf("max").forGetter(DensityFunctions.Planetoids::max),
+                    Codec.INT.fieldOf("gap").forGetter(DensityFunctions.Planetoids::gap)
+                )
+                .apply(i, DensityFunctions.Planetoids::new)
+        );
+        public static final KeyDispatchDataCodec<DensityFunctions.Planetoids> CODEC = DensityFunctions.makeCodec(DATA_CODEC);
+        private static final int Y_MIN = -64, Y_MAX = 320;
+
+        private long hash(final long a, final long b, final long c) {
+            long h = a * 3129871L ^ b * 116129781L ^ c * 982451653L;
+            h = h * h * 42317861L + h * 11L;
+            return h;
+        }
+
+        private int rad(final int cx, final int cy, final int cz) {
+            long h = hash(cx, cy, cz);
+            return this.min + (int) ((h & 0x7FFFFFFFL) % (this.max - this.min + 1));
+        }
+
+        private int off(final int cx, final int cy, final int cz, final int r, final int seed) {
+            long h = hash(cx + seed, cy + seed * 2, cz + seed * 3);
+            int m = (this.gap - r * 2) / 2;
+            if (m <= 0) return 0;
+            return (int) ((h & 0x7FFFFFFFL) % (m * 2 + 1)) - m;
+        }
+
+        @Override
+        public double compute(final DensityFunction.FunctionContext ctx) {
+            int x = ctx.blockX(), y = ctx.blockY(), z = ctx.blockZ();
+            int cx = Math.floorDiv(x, this.gap), cy = Math.floorDiv(y, this.gap), cz = Math.floorDiv(z, this.gap);
+            double best = Double.MAX_VALUE;
+            for (int dx = -1; dx <= 1; dx++) {
+                for (int dy = -1; dy <= 1; dy++) {
+                    for (int dz = -1; dz <= 1; dz++) {
+                        int nx = cx + dx, ny = cy + dy, nz = cz + dz;
+                        int r = rad(nx, ny, nz);
+                        int py = ny * this.gap + this.gap / 2 + off(nx, ny, nz, r, 1);
+                        if (py - r < Y_MIN || py + r > Y_MAX) continue;
+                        int px = nx * this.gap + this.gap / 2 + off(nx, ny, nz, r, 2);
+                        int pz = nz * this.gap + this.gap / 2 + off(nx, ny, nz, r, 3);
+                        int ddx = x - px, ddy = y - py, ddz = z - pz;
+                        double d = Math.sqrt(ddx * ddx + ddy * ddy + ddz * ddz) - r;
+                        if (d < best) best = d;
+                    }
+                }
+            }
+            return best <= 0 ? 1.0 : -1.0;
+        }
+
+        @Override
+        public double minValue() { return -1.0; }
+
+        @Override
+        public double maxValue() { return 1.0; }
+
+        @Override
+        public KeyDispatchDataCodec<? extends DensityFunction> codec() { return CODEC; }
+    }
